#!/usr/bin/env bash
# Generated by ax-harness-kit (F669 Tier 2-B S3) for {{projectName}}
# Installs tmux-resurrect + tmux-continuum + prune-resurrect hook.
# Absorbed from S293 install-tmux-hooks.sh pattern.
# Usage: bash scripts/setup/patch-tmux.sh
# Safe to re-run (idempotent).

set -eu

# Resolve real user home
TARGET_HOME="${AX_TARGET_HOME:-$(getent passwd "$USER" 2>/dev/null | cut -d: -f6)}"
TARGET_HOME="${TARGET_HOME:-$HOME}"

TMUX_DIR="$TARGET_HOME/.tmux"
TMUX_CONF="$TARGET_HOME/.tmux.conf"
PLUGINS_DIR="$TMUX_DIR/plugins"
TPM_DIR="$PLUGINS_DIR/tpm"
RESURRECT_DIR="$PLUGINS_DIR/tmux-resurrect"
CONTINUUM_DIR="$PLUGINS_DIR/tmux-continuum"

SHARED_CONF="${CLAUDE_CONFIG_DIR:-$TARGET_HOME/.claude}/scripts/tmux-plugins.conf"
SOURCE_LINE="source-file ~/.claude/scripts/tmux-plugins.conf"

echo "🔧 ax-harness tmux patch — project: {{projectName}}"
echo "   target HOME: $TARGET_HOME"
echo ""

mkdir -p "$PLUGINS_DIR"

# ============================================================
# Step 1: Install TPM (tmux plugin manager)
# ============================================================
echo "=== Step 1: TPM ==="
if [ -d "$TPM_DIR/.git" ]; then
  echo "✓ TPM 이미 설치됨"
else
  git clone https://github.com/tmux-plugins/tpm "$TPM_DIR"
  echo "✓ TPM 설치 완료: $TPM_DIR"
fi

# ============================================================
# Step 2: Install tmux-resurrect
# ============================================================
echo ""
echo "=== Step 2: tmux-resurrect ==="
if [ -d "$RESURRECT_DIR/.git" ]; then
  echo "✓ tmux-resurrect 이미 설치됨"
else
  git clone https://github.com/tmux-plugins/tmux-resurrect "$RESURRECT_DIR"
  echo "✓ tmux-resurrect 설치 완료"
fi

# ============================================================
# Step 3: Install tmux-continuum
# ============================================================
echo ""
echo "=== Step 3: tmux-continuum ==="
if [ -d "$CONTINUUM_DIR/.git" ]; then
  echo "✓ tmux-continuum 이미 설치됨"
else
  git clone https://github.com/tmux-plugins/tmux-continuum "$CONTINUUM_DIR"
  echo "✓ tmux-continuum 설치 완료"
fi

# ============================================================
# Step 4: Inject plugins conf into ~/.tmux.conf
# ============================================================
echo ""
echo "=== Step 4: ~/.tmux.conf 플러그인 설정 주입 ==="

if [ -f "$SHARED_CONF" ]; then
  if grep -qF "$SOURCE_LINE" "$TMUX_CONF" 2>/dev/null; then
    echo "✓ 이미 주입됨"
  else
    BACKUP_CONF="${TMUX_CONF}.bak.$(date +%Y%m%d_%H%M%S)"
    [ -f "$TMUX_CONF" ] && cp "$TMUX_CONF" "$BACKUP_CONF" && \
      echo "💾 백업: $BACKUP_CONF"
    printf "\n# ax-harness tmux plugins\n%s\n" "$SOURCE_LINE" >> "$TMUX_CONF"
    echo "✓ $SOURCE_LINE 주입됨"
  fi
else
  echo "⚠️  $SHARED_CONF 없음 — ~/.tmux.conf에 직접 플러그인 설정 추가"
  if ! grep -q "tmux-resurrect" "$TMUX_CONF" 2>/dev/null; then
    cat >> "$TMUX_CONF" <<'TMUX_PLUGINS'

# ax-harness tmux plugins (generated by ax-harness-kit)
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @continuum-save-interval '15'
set -g @continuum-restore 'on'
set -g @resurrect-capture-pane-contents 'on'
run '~/.tmux/plugins/tpm/tpm'
TMUX_PLUGINS
    echo "✓ 플러그인 설정 직접 추가됨"
  fi
fi

# ============================================================
# Step 5: Reload tmux config (if server is running)
# ============================================================
echo ""
echo "=== Step 5: tmux 서버 reload ==="
if tmux info &>/dev/null 2>&1; then
  tmux source-file "$TMUX_CONF" 2>/dev/null && \
    echo "✓ ~/.tmux.conf 재로드 완료" || \
    echo "⚠️  reload 실패 — 새 tmux 세션에서 자동 적용됨"
else
  echo "ℹ️  tmux 서버 없음 — 새 세션 시작 시 자동 적용됨"
fi

echo ""
echo "✅ tmux + resurrect 설정 완료"
echo "   prefix + I  → TPM 플러그인 설치 (첫 번째 세션)"
echo "   prefix + Ctrl-s → 세션 저장"
echo "   prefix + Ctrl-r → 세션 복원"
