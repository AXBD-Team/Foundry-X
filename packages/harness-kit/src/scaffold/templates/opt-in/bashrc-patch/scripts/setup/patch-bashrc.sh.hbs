#!/usr/bin/env bash
# Generated by ax-harness-kit (F669 Tier 2-B) for {{projectName}}
# Patches ~/.bashrc with Sprint workflow functions using idempotent markers.
# Usage: bash scripts/setup/patch-bashrc.sh
# Safe to re-run (idempotent via # ax-harness BEGIN/END markers).

set -eu

# AX_TARGET_HOME: shell $HOME can be overridden in Claude Code (HOME=~/.claude-work)
# Resolve real user home via passwd DB, falling back to $HOME.
TARGET_HOME="${AX_TARGET_HOME:-$(getent passwd "$USER" 2>/dev/null | cut -d: -f6)}"
TARGET_HOME="${TARGET_HOME:-$HOME}"
BASHRC="$TARGET_HOME/.bashrc"
MARKER_BEGIN="# ax-harness BEGIN"
MARKER_END="# ax-harness END"

echo "🔧 ax-harness bashrc patch — project: {{projectName}}"
echo "   target: $BASHRC"
echo ""

# Remove existing block if present (idempotent update)
if grep -q "$MARKER_BEGIN" "$BASHRC" 2>/dev/null; then
  echo "♻️  기존 ax-harness 블록 교체 중..."
  sed -i "/$MARKER_BEGIN/,/$MARKER_END/d" "$BASHRC"
fi

# Backup
BACKUP="${BASHRC}.bak.$(date +%Y%m%d_%H%M%S)"
cp "$BASHRC" "$BACKUP" 2>/dev/null && echo "💾 백업: $BACKUP" || true

# Append 13 Sprint workflow functions between markers
cat >> "$BASHRC" <<'AX_HARNESS_FUNCTIONS'
# ax-harness BEGIN
# Sprint workflow functions — generated by ax-harness-kit
# Re-generate: bash scripts/setup/patch-bashrc.sh

CLAUDE_WT_BASE="${CLAUDE_WT_BASE:-$HOME/work/worktrees}"
WTE="${WTE:-$(command -v wt.exe 2>/dev/null || echo '')}"
WSL_DISTRO="${WSL_DISTRO:-Ubuntu-24.04}"
AX_REAL_HOME="${AX_REAL_HOME:-/home/$USER}"

_cw_project() {
  local root
  root=$(git rev-parse --show-toplevel 2>/dev/null) || return 1
  basename "$root"
}

# wtsplit [name] — ad-hoc worktree pane (scratch 브랜치)
wtsplit() {
  local name="${1:-scratch-$(date +%H%M%S)}"
  local project
  project=$(basename "$(git rev-parse --show-toplevel 2>/dev/null)") || {
    echo "❌ git 프로젝트 안에서 실행해주세요"; return 1;
  }
  local wt_path="$CLAUDE_WT_BASE/$project/$name"
  local branch="scratch/$name"
  git worktree add -b "$branch" "$wt_path" HEAD 2>/dev/null || \
    git worktree add "$wt_path" "$branch" 2>/dev/null || {
      echo "❌ worktree 생성 실패: $wt_path"; return 1;
    }
  echo "✅ scratch worktree: $wt_path"
  if tmux display-message -p '' >/dev/null 2>&1; then
    tmux split-window -h -c "$wt_path" "exec bash" && \
      echo "📟 tmux split 생성됨"
  fi
}

# _cc_billing_guard — API key 과금 방어
_cc_billing_guard() {
  local cc_json="$HOME/.claude.json"
  if [ -f "$cc_json" ] && grep -q '"primaryApiKey"' "$cc_json" 2>/dev/null; then
    echo "❌ .claude.json에 primaryApiKey 감지 — API 과금 방지로 실행 차단" >&2
    echo "   해결: _cc_remove_api_key 실행 후 claude auth login" >&2
    return 1
  fi
}

# _cc_remove_api_key — primaryApiKey 제거
_cc_remove_api_key() {
  local cc_json="$HOME/.claude.json"
  if [ ! -f "$cc_json" ]; then
    echo "ℹ️  $cc_json 없음"; return 0;
  fi
  if command -v python3 >/dev/null 2>&1; then
    python3 -c "
import json, sys
with open('$cc_json') as f: d = json.load(f)
d.pop('primaryApiKey', None)
with open('$cc_json', 'w') as f: json.dump(d, f, indent=2)
print('✅ primaryApiKey 제거 완료')
"
  else
    echo "⚠️  python3 없음 — 수동으로 $cc_json에서 primaryApiKey 제거하세요"
  fi
}

# ccs — Claude Code 구독 래퍼 (billing guard 포함)
ccs() { _cc_billing_guard && command ccs "$@"; }

# ccw — dangerously-skip-permissions Claude 래퍼
ccw() { _cc_billing_guard && command claude --dangerously-skip-permissions "$@"; }

# _sprint_ensure_monitor — Sprint daemon 시작 보장
_sprint_ensure_monitor() {
  local project_root
  project_root=$(git rev-parse --show-toplevel 2>/dev/null) || return 0
  local daemon_script="$project_root/scripts/task/task-daemon.sh"
  [ -f "$daemon_script" ] && bash "$daemon_script" --bg 2>/dev/null || true
}

# sprint <N> [N2 ...] — Sprint worktree 생성 + WT 탭
sprint() {
  [ $# -eq 0 ] && { echo "Usage: sprint <N> [N2 N3 ...]"; return 1; }
  local project
  project=$(_cw_project) || { echo "❌ git 프로젝트 안에서 실행해주세요"; return 1; }

  for num in "$@"; do
    local branch="sprint/${num}"
    local wt_dir="$CLAUDE_WT_BASE/$project/sprint-${num}"

    if [ ! -d "$wt_dir" ]; then
      mkdir -p "$CLAUDE_WT_BASE/$project"
      if git rev-parse --verify "$branch" >/dev/null 2>&1; then
        git worktree add "$wt_dir" "$branch" || continue
      else
        git worktree add -b "$branch" "$wt_dir" HEAD || continue
      fi
      echo "✅ Sprint $num 워크트리: $wt_dir"
    else
      echo "📂 Sprint $num 이미 존재: $wt_dir"
    fi

    local f_items=""
    f_items=$(awk -F'|' -v s="Sprint ${num}" '{
      col4=$4; gsub(/^[[:space:]]+|[[:space:]]+$/,"",col4)
      if (col4 == s) { match($2,/F[0-9]+/); if(RSTART) print substr($2,RSTART,RLENGTH) }
    }' SPEC.md 2>/dev/null | paste -sd, -)

    local tab_title="${project}: Sprint ${num}"
    [ -n "$f_items" ] && tab_title="${tab_title} — ${f_items}"
    local session_name="sprint-${num}"
    [ -n "$f_items" ] && session_name="sprint-${num} ${f_items}"

    if [ -n "$WTE" ] && [ -x "$WTE" ] 2>/dev/null; then
      "$WTE" -w 0 new-tab --title "$tab_title" \
        wsl.exe -d "$WSL_DISTRO" -- bash -lic \
          "cd '$wt_dir' && exec bash" \
        2>/dev/null && echo "🪟 WT 탭 '$tab_title' 열림" || true
    else
      if ! tmux has-session -t "$session_name" 2>/dev/null; then
        tmux new-session -d -s "$session_name" -c "$wt_dir" \
          "bash -i -l -c 'echo Sprint $num ready; exec bash'"
        echo "📟 tmux 세션 '$session_name' 생성됨"
      fi
    fi

    local sig_dir="/tmp/sprint-signals"
    mkdir -p "$sig_dir"
    local sig_file="$sig_dir/${project}-${num}.signal"
    if [ ! -f "$sig_file" ]; then
      cat > "$sig_file" <<SIGNAL
STATUS=CREATED
SPRINT_NUM=${num}
PROJECT=${project}
F_ITEMS=${f_items}
BRANCH=${branch}
PR_NUM=
CHECKPOINT=
TIMESTAMP=$(date -Iseconds)
SIGNAL
    fi

    _sprint_ensure_monitor
  done
}

# sprint-review <N> — Sprint 브랜치 리뷰
sprint-review() {
  local num="${1:?Usage: sprint-review <N>}"
  local project; project=$(_cw_project) || return 1
  local wt_dir="$CLAUDE_WT_BASE/$project/sprint-${num}"
  [ -d "$wt_dir" ] || { echo "❌ WT 없음: $wt_dir"; return 1; }
  echo "📋 Sprint $num 리뷰 — $wt_dir"
  git -C "$wt_dir" log --oneline "master..sprint/${num}" 2>/dev/null
  git -C "$wt_dir" diff --stat "master..sprint/${num}" 2>/dev/null
}

# sprint-pr <N> — Sprint 브랜치 Push + PR 생성
sprint-pr() {
  local num="${1:?Usage: sprint-pr <N>}"
  local project; project=$(_cw_project) || return 1
  local wt_dir="$CLAUDE_WT_BASE/$project/sprint-${num}"
  local branch="sprint/${num}"
  git -C "$wt_dir" push -u origin "$branch" 2>/dev/null || \
    git -C "$wt_dir" push --set-upstream origin "$branch"
  gh pr create --base master --head "$branch" \
    --title "feat: Sprint ${num}" \
    --body "Auto-generated Sprint ${num} PR" 2>/dev/null || true
}

# sprint-done <N> — Sprint worktree + 브랜치 정리
sprint-done() {
  local num="${1:?Usage: sprint-done <N>}"
  local project; project=$(_cw_project) || return 1
  local wt_dir="$CLAUDE_WT_BASE/$project/sprint-${num}"
  local branch="sprint/${num}"
  git worktree remove "$wt_dir" --force 2>/dev/null && \
    echo "✅ worktree 제거: $wt_dir" || true
  git branch -D "$branch" 2>/dev/null && \
    echo "✅ 브랜치 제거: $branch" || true
}

# ccw-sprint — Sprint WT에서 ccw 실행
ccw-sprint() {
  local num="${1:?Usage: ccw-sprint <N>}"
  local project; project=$(_cw_project) || return 1
  local wt_dir="$CLAUDE_WT_BASE/$project/sprint-${num}"
  [ -d "$wt_dir" ] || { echo "❌ WT 없음: $wt_dir"; return 1; }
  cd "$wt_dir" && ccw "${@:2}"
}

# ccw-auto — Sprint 전체 자동화
ccw-auto() {
  ccw /ax:sprint-autopilot "$@"
}

# sprints — 활성 Sprint worktree 목록
sprints() {
  echo ""
  echo "  🌳 Active Worktrees"
  echo "  ──────────────────────────"
  git worktree list 2>/dev/null | while read -r line; do
    echo "  $line"
  done
  echo ""
}
# ax-harness END
AX_HARNESS_FUNCTIONS

echo ""
echo "✅ ~/.bashrc에 ax-harness 함수 설치 완료 (13 함수)"
echo "   source ~/.bashrc  (또는 새 터미널 열기)"
echo ""
echo "📦 포함된 함수:"
echo "   wtsplit, _cc_billing_guard, _cc_remove_api_key, ccs, ccw,"
echo "   _sprint_ensure_monitor, sprint(), sprint-review, sprint-pr,"
echo "   sprint-done, ccw-sprint, ccw-auto, sprints"
