{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '\\.env|credentials|pnpm-lock\\.yaml'; then echo 'BLOCKED: Protected file edit blocked (.env, credentials, lock files)'; exit 2; fi",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-bash-guard.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/task/heartbeat-hook.sh\" 2>/dev/null || true",
            "timeout": 5000,
            "statusMessage": "heartbeat"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-format.sh\"",
            "timeout": 15000,
            "statusMessage": "eslint --fix"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-typecheck.sh\"",
            "timeout": 60000,
            "statusMessage": "typecheck"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-test-warn.sh\"",
            "timeout": 5000,
            "statusMessage": "test coverage check"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"${CLAUDE_PROJECT_DIR:-$PWD}\" 2>/dev/null && git rev-parse --is-inside-work-tree >/dev/null 2>&1 && bash \"$CLAUDE_PROJECT_DIR/scripts/task/git-orphan-scan.sh\" --quiet 2>/dev/null || true'",
            "timeout": 60000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/task/sprint-notification-surface.sh\" 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
